# ─────────────────────────────────────────────────────────────────────────────
# Waxcelerate — environment variables
# Copy to `.env` for local dev. In production, set these in Vercel → Settings →
# Environment Variables. Nothing here is shipped to the browser EXCEPT the
# VITE_* keys (those are public by design).
# ─────────────────────────────────────────────────────────────────────────────

# ── Stripe (required for checkout) ───────────────────────────────────────────
# Dashboard → Developers → API keys. Use sk_test_… until you go live.
STRIPE_SECRET_KEY=sk_test_xxx
# Dashboard → Developers → Webhooks → your endpoint → Signing secret.
STRIPE_WEBHOOK_SECRET=whsec_xxx
# Dashboard → Shipping rates → copy the shr_… IDs.
STRIPE_SHIPPING_FREE=shr_xxx        # €0 rate (applied to orders ≥ €50)
STRIPE_SHIPPING_STANDARD=shr_xxx    # standard rate (orders < €50)
# Fallback origin for success/cancel URLs if the request has no Origin header.
SITE_URL=https://waxcelerate.de

# ── Admin panel + inventory (Upstash Redis) ──────────────────────────────────
# Password for /admin. If unset, the admin panel stays locked.
ADMIN_PASSWORD=change-me
# Upstash → your database → REST API. Optional: without it, stock = unlimited.
UPSTASH_REDIS_REST_URL=https://xxx.upstash.io
UPSTASH_REDIS_REST_TOKEN=xxx

# ── Orders DB (Supabase) — optional ──────────────────────────────────────────
# Used by the webhook to store each order. Service-role key is server-only.
SUPABASE_URL=https://xxx.supabase.co
SUPABASE_SERVICE_ROLE_KEY=xxx

# ── Order confirmation email (Resend) — optional ─────────────────────────────
RESEND_API_KEY=re_xxx

# ── Analytics (PostHog) — public, shipped to the browser ─────────────────────
# Project Settings → Project API Key. Use the EU host for GDPR.
VITE_POSTHOG_KEY=phc_xxx
VITE_POSTHOG_HOST=https://eu.i.posthog.com
